APP_NAME="FastPOS"
APP_ENV=production
APP_KEY=base64:CHANGE_ME_RUN_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://app.yourdomain.com
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=fastpos_prod
DB_USERNAME=fastpos_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# DB_SSLMODE=require          # Uncomment for managed cloud DBs (RDS, Supabase, Neon)
# DB_SSLCERT=                 # Path to client cert if mutual TLS required
# DB_OPTIONS='{"sslmode":"require"}'

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.com
SESSION_SECURE_COOKIE=true

# ── Cache ────────────────────────────────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=fastpos_prod_

# ── Queue ─────────────────────────────────────────────────────────────────────
# REQUIRED for production: never use 'database' or 'sync' in production
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids
# Worker recommendation: php artisan queue:work redis --tries=3 --backoff=60 --timeout=120 --max-jobs=500

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=fastpos_jobs
REDIS_QUEUE_RETRY_AFTER=90

# ── Mail (Production SMTP) ────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="FastPOS"

# ── Filesystem ───────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
# For S3/R2: FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=fastpos-uploads

# ── Broadcast ────────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=app.yourdomain.com
