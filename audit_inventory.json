{
  "modules": [
    "Inventory",
    "POS",
    "Tenant",
    "SuperAdmin",
    "Reporting",
    "Sales",
    "HRM",
    "CRM"
  ],
  "pages_to_endpoints": [
    {
      "page": "src/app/(pos)/terminal/page.tsx",
      "endpoint": "api/v1/tenant/sales/checkout",
      "controller": "TransactionController@checkout"
    },
    {
      "page": "src/app/[domain]/(dashboards)/superadmin/backups/page.tsx",
      "endpoint": "api/v1/superadmin/backups",
      "controller": "BackupController@index"
    },
    {
      "page": "src/app/[domain]/(dashboards)/superadmin/audit-logs/page.tsx",
      "endpoint": "api/v1/superadmin/audit-logs",
      "controller": "AuditLogController@index"
    },
    {
      "page": "src/app/[domain]/(dashboards)/business/reports/inventory-valuation/page.tsx",
      "endpoint": "api/v1/tenant/reports/valuation",
      "controller": "FinancialReportController@valuation"
    }
  ],
  "dead_or_orphan_checks": {
    "controllers_without_views": [
      "App\\Modules\\SuperAdmin\\Controllers\\SystemController@broadcastAnnouncement"
    ],
    "views_without_controllers": [
      "src/app/[domain]/(dashboards)/business/hr/payroll/page.tsx"
    ]
  },
  "domain_driven_design_violations": [
    "App\\Modules\\Tenant\\Controllers\\SuperadminController (Belongs in SuperAdmin module)"
  ]
}
